<div class="local-consentmanager-preferences">

    <h2>{{#str}} mypreferences_title, local_consentmanager {{/str}}</h2>
    <p class="text-muted">{{#str}} mypreferences_intro, local_consentmanager {{/str}}</p>

    {{! Current consent status per category }}
    <div class="consentmanager-pref-categories">
        {{#categories}}
        <div class="card mb-3 consentmanager-pref-cat" data-catid="{{id}}">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="card-title mb-1">
                            {{name}}
                            {{#required}}
                                <span class="badge bg-secondary ms-1">
                                    {{#str}} cat_required, local_consentmanager {{/str}}
                                </span>
                            {{/required}}
                        </h5>
                        <p class="card-text small text-muted">{{{description}}}</p>
                        <p class="mb-0">
                            {{#given}}
                                <span class="badge bg-success">
                                    <i class="fa fa-check" aria-hidden="true"></i>
                                    {{#str}} status_given, local_consentmanager {{/str}}
                                </span>
                            {{/given}}
                            {{^given}}
                                <span class="badge bg-secondary">
                                    {{#str}} status_declined, local_consentmanager {{/str}}
                                </span>
                            {{/given}}
                        </p>
                    </div>
                    <div class="ms-3">
                        {{#can_withdraw}}
                        <button type="button"
                                class="btn btn-sm btn-outline-danger consentmanager-withdraw"
                                data-catid="{{id}}"
                                data-sesskey="{{sesskey}}">
                            {{#str}} btn_withdraw, local_consentmanager {{/str}}
                        </button>
                        {{/can_withdraw}}
                        {{^given}}{{^required}}
                        <button type="button"
                                class="btn btn-sm btn-outline-primary consentmanager-give"
                                data-catid="{{id}}"
                                data-sesskey="{{sesskey}}">
                            {{#str}} btn_give, local_consentmanager {{/str}}
                        </button>
                        {{/required}}{{/given}}
                    </div>
                </div>
            </div>
        </div>
        {{/categories}}
    </div>

    {{! Consent history }}
    {{#has_history}}
    <h3 class="mt-4">{{#str}} history_title, local_consentmanager {{/str}}</h3>
    <table class="table table-sm table-bordered">
        <thead>
            <tr>
                <th>{{#str}} history_col_time, local_consentmanager {{/str}}</th>
                <th>{{#str}} history_col_action, local_consentmanager {{/str}}</th>
                <th>{{#str}} history_col_category, local_consentmanager {{/str}}</th>
                <th>{{#str}} history_col_revision, local_consentmanager {{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#history}}
            <tr>
                <td>{{timecreated}}</td>
                <td>{{action}}</td>
                <td>{{catname}}</td>
                <td>{{revision}}</td>
            </tr>
            {{/history}}
        </tbody>
    </table>
    {{/has_history}}
    {{^has_history}}
    <p class="text-muted mt-4">{{#str}} history_empty, local_consentmanager {{/str}}</p>
    {{/has_history}}

    {{#privacypolicy_url}}
    <p class="mt-3">
        <a href="{{privacypolicy_url}}" target="_blank" rel="noopener noreferrer">
            {{#str}} privacypolicy, local_consentmanager {{/str}}
        </a>
    </p>
    {{/privacypolicy_url}}

</div>
